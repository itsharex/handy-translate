appname = 'handy-translate'
translate_way = 'deepseek'
toolbar_mode = 'translate'

[keyboards]
screenshot = ['ctrl', 'shift', 'f']
toolBar = ['center', '', '']

[translate]
[translate.baidu]
name = '百度翻译'
appID = ''
key = ''

[translate.deepseek]
name = 'DeepSeek'
appID = 'deepseek'
key = ''

[translate.youdao]
name = '有道翻译'
appID = ''
key = ''

[translate.google]
name = 'Google Gemini'
appID = 'google'
key = ''
base_url = 'https://generativelanguage.googleapis.com/v1beta/openai'
model = 'gemini-2.0-flash'

[explain_templates]
default_template = 'programmer'

[explain_templates.templates]
[explain_templates.templates.academic]
name = '文学视角'
description = '适合解释文学词语'
template = "你是一位拥有极其丰富阅读经验的学者，对古今中外的历史、哲学、文学、科技与人类思想演变有深刻理解。\n请用简洁、专业、易于程序员快速理解的方式解释以下词语。\n要求：\n1. 结合历史与思想背景，点出它的本质与现实意义\n2. 可以快速理解的方式解释它的核心含义\n3. 回答保持在 3～5 句话，言简意赅、富有启发性\n词语：{{.text}}"

[explain_templates.templates.programmer]
name = '技术视角'
description = '适合解释编程、技术相关术语'
template = "你是一名资深程序员，对计算机系统、网络、编程语言和工程实践有深入理解。\n请用简洁、专业、易于程序员快速理解的方式解释以下技术术语。\n要求：\n1. 用程序员的视角说明它是什么及核心机制或原理\n2. 简述它在实际开发或系统中的常见用途\n3. 控制在 3~5 句话内，直击要点，不赘述\n术语：{{.text}}"

[history]
enabled = true
storage_path = './data'
